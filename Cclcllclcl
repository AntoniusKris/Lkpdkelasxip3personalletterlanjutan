<script>
// ===========================
// STATE
// ===========================
let totalScore = 0;
let currentSection = 0;
let totalSections = 8;
let completedSections = [];
let studentData = {};
let highlightTool = 'present';
let selectedTopic = '';
let dragOrder = [];

const sectionNames = [
  'Warm Up',
  'Identify Context',
  'Structure Builder',
  'Language Features',
  'Micro Writing',
  'Full Letter',
  'Reflection',
  'Results'
];

const correctStructure = ['Date','Greeting','Opening Paragraph','Body Paragraph(s)','Closing Statement','Signature'];

// ===========================
// INIT
// ===========================
document.getElementById('studentDate').value = new Date().toISOString().split('T')[0];
buildStepDots();
buildHighlightText();

function buildStepDots() {
  const d = document.getElementById('stepDots');
  d.innerHTML = '';
  for(let i=0;i<totalSections;i++){
    const dot = document.createElement('div');
    dot.className = 'step-dot';
    dot.id = 'dot'+i;
    d.appendChild(dot);
  }
}

function updateProgress() {
  const pct = Math.round((completedSections.length / totalSections) * 100);
  document.getElementById('progressBar').style.width = pct + '%';
  document.getElementById('progressPct').textContent = pct + '%';
  for(let i=0;i<totalSections;i++){
    const dot = document.getElementById('dot'+i);
    dot.className = 'step-dot';
    if(completedSections.includes(i)) dot.classList.add('done');
    if(i === currentSection-1) dot.classList.add('active');
  }
}

function updateScore(pts) {
  totalScore += pts;
  document.getElementById('totalScore').textContent = totalScore;
  // animate
  if(pts > 0) showPointAnim('+' + pts + ' pts');
}

function showSection(num) {
  // hide all
  document.querySelectorAll('.section-card').forEach(c=>c.classList.remove('active'));
  document.getElementById('studentInfo').style.display = 'none';
  const s = document.getElementById('sec'+num);
  if(s){ s.classList.add('active'); currentSection = num; }
  // Build section 3 fresh every time it's shown
  if(num === 3) buildDragDrop();
  updateProgress();
  window.scrollTo({top:0,behavior:'smooth'});
}

// ===========================
// START
// ===========================
function startLKPD() {
  const name = document.getElementById('studentName').value.trim();
  const cls = document.getElementById('studentClass').value.trim();
  if(!name || !cls){ alert('Please fill in your name and class first!'); return; }
  studentData = {
    name, cls,
    studentNo: document.getElementById('studentNo').value,
    date: document.getElementById('studentDate').value
  };
  document.getElementById('studentInfo').style.display = 'none';
  showSection(1);
  showBadge('🌟','Letter Starter','You started your LKPD journey! Let\'s go!');
}

// ===========================
// SECTION 1
// ===========================
let q1done=false, q2done=false;

function selectMC(qid, el, isCorrect, letter) {
  const opts = document.getElementById(qid+'opts').querySelectorAll('.mc-opt');
  opts.forEach(o => { o.classList.remove('selected','correct','wrong'); });
  
  // reveal correct
  opts.forEach(o => {
    const l = o.querySelector('.opt-letter').textContent.toLowerCase();
    if(isCorrect && l === letter) o.classList.add('correct');
    else if(!isCorrect && l === letter) o.classList.add('wrong');
  });

  // mark correct answer
  if(qid==='q1'){
    opts[1].classList.add('correct'); // B is correct
    if(!q1done){
      if(letter==='b'){ updateScore(10); showFeedback('q1fb','good','✅ Correct! Personal letters are for sharing thoughts and feelings with people we know.'); }
      else { showFeedback('q1fb','bad','❌ Not quite. Personal letters are mainly for sharing personal thoughts, feelings, and news. The correct answer is B.'); }
      q1done=true;
    }
  }
  if(qid==='q2'){
    opts[2].classList.add('correct'); // C is correct
    if(!q2done){
      if(letter==='c'){ updateScore(10); showFeedback('q2fb','good','✅ Correct! A childhood friend is a personal relationship — perfect for a personal letter!'); }
      else { showFeedback('q2fb','bad','❌ Not quite. We write personal letters to people we know personally. A childhood friend (C) is the best answer.'); }
      q2done=true;
    }
  }
}

function submitSection1() {
  const q3 = document.getElementById('q3ans').value.trim();
  if(q3.length < 20){ showFeedback('q3fb','bad','✏️ Please share a bit more in your reflection (at least 20 characters).'); return; }
  if(q3.length > 0 && !completedSections.includes(0)){
    updateScore(5);
    showFeedback('q3fb','good','✅ Thanks for sharing! +5 pts for your reflection!');
  }
  if(!completedSections.includes(0)){ completedSections.push(0); updateProgress(); }
  setTimeout(()=>showSection(2), 600);
}

// ===========================
// SECTION 2
// ===========================
function submitSection2() {
  const sender = document.getElementById('t2sender').value.trim().toLowerCase();
  const receiver = document.getElementById('t2receiver').value.trim().toLowerCase();
  const relation = document.getElementById('t2relation').value;
  const situation = document.getElementById('t2situation').value;

  if(!sender||!receiver||!relation||!situation){
    showFeedback('sec2fb','bad','⚠️ Please complete all four tasks before continuing.');
    return;
  }

  let pts = 0;
  let feedback = '';
  if(sender.includes('dina')) pts+=5;
  if(receiver.includes('sarah')) pts+=5;
  if(relation==='friends') pts+=5; else feedback+=' Tip: The relationship between Dina and Sarah appears to be close friends.';
  if(situation==='share-news') pts+=5; else feedback+=' Tip: The main purpose is to share exciting personal news!';

  if(!completedSections.includes(1)){
    updateScore(pts);
    completedSections.push(1);
    updateProgress();
  }
  showFeedback('sec2fb','good','✅ Great analysis! Moving to the next section...'+feedback);
  setTimeout(()=>showSection(3), 800);
}

// ===========================
// SECTION 3 – TAP-TO-PLACE
// ===========================
const structureParts = [
  { label: 'Date',              hint: 'e.g. 15 October 2024' },
  { label: 'Greeting',         hint: 'e.g. Dear Sarah,' },
  { label: 'Opening Paragraph',hint: 'Friendly intro – how are you?' },
  { label: 'Body Paragraph(s)',hint: 'Main news / feelings' },
  { label: 'Closing Statement',hint: 'e.g. Miss you lots,' },
  { label: 'Signature',        hint: 'e.g. Love, Dina' },
];

// Which pool card is currently tapped/selected
let _selectedPoolLabel = null;

function buildDragDrop() {
  const pool = document.getElementById('dragPool');
  const zone = document.getElementById('dropZone');
  _selectedPoolLabel = null;

  // ── Pool ────────────────────────────────────────────────────────────────
  pool.innerHTML = '<h4>📦 Parts to Arrange – tap to select</h4>';
  const shuffled = [...structureParts].sort(() => Math.random() - 0.5);

  shuffled.forEach(part => {
    const el = document.createElement('div');
    el.className = 'pool-item';
    el.dataset.label = part.label;
    el.innerHTML =
      '<span>📄</span>' +
      '<span>' + part.label +
        '<span class="pool-hint">' + part.hint + '</span>' +
      '</span>';

    el.addEventListener('click', () => {
      // Deselect if already selected
      if (_selectedPoolLabel === part.label) {
        _selectedPoolLabel = null;
        el.classList.remove('selected');
        updateIndicator();
        return;
      }
      // Deselect any other selected pool item
      pool.querySelectorAll('.pool-item').forEach(p => p.classList.remove('selected'));
      _selectedPoolLabel = part.label;
      el.classList.add('selected');
      updateIndicator();
      // Highlight empty slots as "ready"
      zone.querySelectorAll('.drop-slot').forEach(s => {
        if (!s.dataset.label) s.classList.add('ready');
      });
    });

    pool.appendChild(el);
  });

  // ── Slots ────────────────────────────────────────────────────────────────
  // Keep header + indicator, rebuild only slots
  const existingSlots = zone.querySelectorAll('.drop-slot');
  existingSlots.forEach(s => s.remove());

  for (let i = 0; i < 6; i++) {
    const slot = document.createElement('div');
    slot.className = 'drop-slot';
    slot.dataset.index = i;
    renderSlotEmpty(slot, i);

    slot.addEventListener('click', () => {
      if (slot.dataset.label) {
        // Slot is filled – return item to pool
        returnLabelToPool(slot.dataset.label);
        delete slot.dataset.label;
        slot.classList.remove('filled','correct','wrong','ready');
        renderSlotEmpty(slot, i);
        return;
      }
      // Slot is empty – place selected item if any
      if (!_selectedPoolLabel) return;
      const label = _selectedPoolLabel;
      // Remove from pool
      removeLabelFromPool(label);
      _selectedPoolLabel = null;
      updateIndicator();
      // Clear ready highlight on all slots
      zone.querySelectorAll('.drop-slot').forEach(s => s.classList.remove('ready'));
      // Fill this slot
      slot.dataset.label = label;
      slot.classList.add('filled');
      renderSlotFilled(slot, i, label);
    });

    zone.appendChild(slot);
  }
}

function renderSlotEmpty(slot, idx) {
  slot.innerHTML =
    '<div class="slot-num">' + (idx + 1) + '</div>' +
    '<div class="slot-content"><span class="slot-empty-label">Tap a card above, then tap here</span></div>';
}

function renderSlotFilled(slot, idx, label) {
  slot.innerHTML =
    '<div class="slot-num">' + (idx + 1) + '</div>' +
    '<div class="slot-content"><span class="slot-text">' + label + '</span></div>' +
    '<span class="slot-remove-btn" title="Remove">✕</span>';
  // Wire up the ✕ button separately (so it doesn't bubble wrong)
  slot.querySelector('.slot-remove-btn').addEventListener('click', e => {
    e.stopPropagation();
    returnLabelToPool(label);
    delete slot.dataset.label;
    slot.classList.remove('filled','correct','wrong','ready');
    renderSlotEmpty(slot, idx);
  });
}

function updateIndicator() {
  const ind = document.getElementById('selectedIndicator');
  const lbl = document.getElementById('selectedLabel');
  if (!ind || !lbl) return;
  if (_selectedPoolLabel) {
    lbl.textContent = _selectedPoolLabel;
    ind.classList.add('show');
  } else {
    ind.classList.remove('show');
  }
}

function removeLabelFromPool(label) {
  const pool = document.getElementById('dragPool');
  const el = Array.from(pool.querySelectorAll('.pool-item')).find(e => e.dataset.label === label);
  if (el) el.remove();
}

function returnLabelToPool(label) {
  const pool = document.getElementById('dragPool');
  // Check not already in pool
  const exists = Array.from(pool.querySelectorAll('.pool-item')).find(e => e.dataset.label === label);
  if (exists) return;
  const part = structureParts.find(p => p.label === label);
  if (!part) return;
  const el = document.createElement('div');
  el.className = 'pool-item';
  el.dataset.label = label;
  el.innerHTML =
    '<span>📄</span>' +
    '<span>' + label +
      '<span class="pool-hint">' + part.hint + '</span>' +
    '</span>';
  el.addEventListener('click', () => {
    if (_selectedPoolLabel === label) {
      _selectedPoolLabel = null;
      el.classList.remove('selected');
      updateIndicator();
      return;
    }
    pool.querySelectorAll('.pool-item').forEach(p => p.classList.remove('selected'));
    _selectedPoolLabel = label;
    el.classList.add('selected');
    updateIndicator();
    const zone = document.getElementById('dropZone');
    zone.querySelectorAll('.drop-slot').forEach(s => {
      if (!s.dataset.label) s.classList.add('ready');
    });
  });
  pool.appendChild(el);
}

function resetDrag() {
  _selectedPoolLabel = null;
  buildDragDrop();
  document.getElementById('sec3fb').className = 'feedback-banner';
}

function submitSection3() {
  const zone  = document.getElementById('dropZone');
  const slots = Array.from(zone.querySelectorAll('.drop-slot'));
  const order = slots.map(s => s.dataset.label || '');

  if (order.some(o => !o)) {
    showFeedback('sec3fb', 'bad', '⚠️ Please fill ALL 6 slots first — tap a card, then tap a slot!');
    return;
  }

  let correct = 0;
  slots.forEach((s, i) => {
    s.classList.remove('correct', 'wrong');
    if (order[i] === correctStructure[i]) { s.classList.add('correct'); correct++; }
    else s.classList.add('wrong');
  });

  if (!completedSections.includes(2)) {
    updateScore(correct * 3);
    completedSections.push(2);
    updateProgress();
  }

  if (correct === 6) {
    showFeedback('sec3fb', 'good', '🎉 Perfect! Order: Date → Greeting → Opening Paragraph → Body Paragraph(s) → Closing Statement → Signature!');
    showConfetti();
    setTimeout(() => showSection(4), 1400);
  } else {
    showFeedback('sec3fb', 'bad', '❌ Got ' + correct + '/6 correct. Red slots are wrong — tap ✕ to remove and rearrange, then check again!');
  }
}
// ===========================
// SECTION 4 – HIGHLIGHT
// ===========================
const letterTokens = [
  {word:'How', type:'present'}, {word:'are', type:'present'}, {word:'you', type:''}, {word:'doing', type:'present'},{word:'?', type:''},
  {word:"I", type:''}, {word:'hope', type:'present'}, {word:'you', type:''}, {word:'and', type:''}, {word:'your', type:''}, {word:'family', type:''}, {word:'are', type:'present'}, {word:'all', type:''}, {word:'in', type:''}, {word:'good', type:''}, {word:'health', type:''}, {word:'.', type:''},
  {word:"I've", type:'present'}, {word:'been', type:'past'}, {word:'thinking', type:'past'}, {word:'about', type:''}, {word:'you', type:''}, {word:'a', type:''}, {word:'lot', type:''}, {word:'lately', type:''},  {word:'.', type:''},
  {word:'I', type:''}, {word:'miss', type:'present'}, {word:'you', type:''}, {word:'so', type:''}, {word:'much', type:'feeling'}, {word:'!', type:''},
  {word:"I'm", type:'present'}, {word:'writing', type:'present'}, {word:'to', type:''}, {word:'share', type:'present'}, {word:'some', type:''}, {word:'exciting', type:'feeling'}, {word:'news', type:''},  {word:'.', type:''},
  {word:'I', type:''}, {word:'still', type:''}, {word:"can't", type:'informal'}, {word:'believe', type:'present'}, {word:'it', type:''}, {word:'!', type:''},
  {word:"It's", type:'informal'}, {word:'been', type:'past'}, {word:'a', type:''}, {word:'rollercoaster', type:'informal'}, {word:'!', type:''},
  {word:'I', type:''}, {word:'really', type:'informal'}, {word:'wish', type:'present'}, {word:'you', type:''}, {word:'were', type:'past'}, {word:'here', type:''}, {word:'.', type:''},
  {word:'Please', type:''}, {word:'write', type:'present'}, {word:'back', type:''}, {word:'when', type:''}, {word:'you', type:''}, {word:'get', type:'present'}, {word:'the', type:''}, {word:'chance', type:''},  {word:'.', type:''},
  {word:"I'd", type:'informal'}, {word:'love', type:'feeling'}, {word:'to', type:''}, {word:'hear', type:'present'}, {word:'how', type:''}, {word:'things', type:''}, {word:'are', type:'present'}, {word:'going', type:'present'}, {word:'.', type:''},
];

function buildHighlightText() {
  const wrap = document.getElementById('highlightableText');
  if(!wrap) return;
  wrap.innerHTML = '';
  letterTokens.forEach((token,i) => {
    if(['.',',','!','?'].includes(token.word)){
      wrap.appendChild(document.createTextNode(token.word + ' '));
      return;
    }
    const span = document.createElement('span');
    span.className = 'highlight-btn';
    span.textContent = token.word;
    span.dataset.index = i;
    span.dataset.type = token.type;
    span.addEventListener('click', () => {
      const current = span.dataset.highlighted || '';
      if(current === highlightTool){ span.className='highlight-btn'; span.dataset.highlighted=''; }
      else { span.className='highlight-btn highlighted-'+highlightTool; span.dataset.highlighted=highlightTool; }
    });
    wrap.appendChild(span);
    wrap.appendChild(document.createTextNode(' '));
  });
}

function selectTool(tool) {
  highlightTool = tool;
  document.querySelectorAll('.legend-item').forEach(l=>l.classList.remove('active-tool'));
  document.getElementById('tool-'+tool).classList.add('active-tool');
}

function submitSection4() {
  const reflection = document.getElementById('sec4reflect').value.trim();
  if(reflection.length < 30){ showFeedback('sec4fb','bad','✏️ Please write a bit more in your reflection (at least 30 characters).'); return; }
  
  // count highlights
  let highlighted = document.querySelectorAll('.highlight-btn[data-highlighted]').length;
  let pts = Math.min(10, highlighted * 1);
  if(reflection.length > 30) pts += 5;

  if(!completedSections.includes(3)){
    updateScore(pts);
    completedSections.push(3);
    updateProgress();
  }
  showFeedback('sec4fb','good',`✅ Great work detecting language features! You highlighted ${highlighted} items. Moving on...`);
  setTimeout(()=>showSection(5), 800);
}

// ===========================
// SECTION 5 – MICRO WRITING
// ===========================
function autoCheck(inputId, fbId, type) {
  const val = document.getElementById(inputId).value.trim();
  const fb = document.getElementById(fbId);
  if(!val){ fb.className='feedback-banner'; return; }
  
  const checks = {
    greeting: () => (val.toLowerCase().includes('dear') || val.toLowerCase().includes('hi') || val.toLowerCase().includes('hello')) && val.includes(','),
    opening: () => val.length > 30,
    body: () => val.length > 40,
    closing: () => val.includes(',') || val.toLowerCase().includes('love') || val.toLowerCase().includes('warmly') || val.toLowerCase().includes('yours')
  };
  
  const tips = {
    greeting: "Try starting with 'Dear [Name],' or a warm greeting with a comma.",
    opening: "Write a friendly opening — ask how they are, mention last contact!",
    body: "Share your main news or feelings in more detail.",
    closing: "Try endings like 'Yours truly,' or 'Warmly,' followed by your name."
  };

  if(checks[type] && checks[type]()){
    showFeedback(fbId,'good','✅ Looks good!');
  } else if(val.length > 5){
    showFeedback(fbId,'info','💡 ' + tips[type]);
  }
}

function submitSection5() {
  const g = document.getElementById('w1greeting').value.trim();
  const o = document.getElementById('w2opening').value.trim();
  const b = document.getElementById('w3body').value.trim();
  const c = document.getElementById('w4closing').value.trim();
  if(!g||!o||!b||!c){ alert('Please complete all four writing parts!'); return; }
  let pts = 0;
  if(g.length>3) pts+=5;
  if(o.length>20) pts+=5;
  if(b.length>30) pts+=5;
  if(c.length>3) pts+=5;
  if(!completedSections.includes(4)){
    updateScore(pts);
    completedSections.push(4);
    updateProgress();
  }
  showSection(6);
}

// ===========================
// SECTION 6 – FULL LETTER
// ===========================
function selectTopic(el, topic) {
  document.querySelectorAll('.topic-opt').forEach(o=>o.classList.remove('selected'));
  el.classList.add('selected');
  selectedTopic = topic;
}

function updateLetterChecklist() {
  const letter = document.getElementById('fullLetter').value;
  const checks = {
    'date': /\d{1,2}[\s\/\-]\w+[\s\/\-]\d{4}|\w+\s+\d{1,2},?\s+\d{4}/i,
    'greeting': /dear\s+\w+|my\s+(dear|friend)|hello\s+\w+/i,
    'opening': /how\s+are\s+you|hope\s+you|i\s+(am\s+writing|want|hope)|it\s+has\s+been/i,
    'body': letter.length > 150,
    'closing': /yours|warmly|sincerely|with\s+love|best\s+(regards|wishes)/i,
    'signature': letter.trim().split('\n').length > 5
  };
  
  ['date','greeting','opening','closing'].forEach(key => {
    const ok = checks[key] ? checks[key].test(letter) : false;
    setCheck(key, ok);
  });
  setCheck('body', letter.length > 150);
  setCheck('signature', letter.trim().split('\n').length > 5 && letter.length > 100);
}

function setCheck(key, val) {
  const cb = document.getElementById('cb-'+key);
  if(!cb) return;
  if(val){ cb.classList.add('checked'); }
  else { cb.classList.remove('checked'); }
}

function submitSection6() {
  const letter = document.getElementById('fullLetter').value.trim();
  if(!selectedTopic){ alert('Please choose who you are writing to!'); return; }
  if(letter.length < 100){ alert('Your letter is too short! Please write at least 100 characters.'); return; }
  
  let pts = 0;
  if(letter.length > 150) pts += 10;
  if(letter.length > 300) pts += 10;
  const checks = document.querySelectorAll('.check-box.checked').length;
  pts += checks * 1.5;
  pts = Math.min(30, Math.round(pts));
  
  if(!completedSections.includes(5)){
    updateScore(pts);
    completedSections.push(5);
    updateProgress();
  }
  showSection(7);
}

// ===========================
// SECTION 7 – REFLECTION
// ===========================
function submitSection7() {
  const refl = document.getElementById('reflection').value.trim();
  if(!completedSections.includes(6)){
    updateScore(5);
    completedSections.push(6);
    updateProgress();
  }
  completedSections.push(7);
  buildFinalScreen();
  showSection(8);
  showConfetti();
}

// ===========================
// SECTION 8 – FINAL
// ===========================
function buildFinalScreen() {
  document.getElementById('finalScoreNum').textContent = totalScore;
  
  let badge, emoji, msg;
  if(totalScore >= 80){
    badge = 'Letter Master'; emoji = '🏆';
    msg = 'Outstanding! You have mastered the personal letter. Your teacher will be impressed!';
  } else if(totalScore >= 60){
    badge = 'Letter Writer'; emoji = '🥈';
    msg = 'Great job! You have a solid understanding of personal letters. Keep practicing!';
  } else {
    badge = 'Letter Learner'; emoji = '📚';
    msg = 'Good effort! Review your notes and practice more. You\'ll get there!';
  }
  
  document.getElementById('finalBadgeEmoji').textContent = emoji;
  document.getElementById('finalBadgeName').textContent = badge;
  document.getElementById('finalMsg').textContent = msg;

  // Summary
  const summary = document.getElementById('answerSummary');
  summary.innerHTML = `
    <strong>Student:</strong> ${studentData.name} | <strong>Class:</strong> ${studentData.cls}<br>
    <strong>Date:</strong> ${studentData.date}<br>
    <strong>Total Score:</strong> ${totalScore} pts | <strong>Badge:</strong> ${emoji} ${badge}<br>
    <strong>Letter Recipient:</strong> ${selectedTopic || 'Not specified'}<br>
    <strong>Reflection Score:</strong> ${document.getElementById('sl1').value}/5 (Structure) | 
    ${document.getElementById('sl2').value}/5 (Independence) | 
    ${document.getElementById('sl3').value}/5 (Enjoyment)<br>
    <strong>Sections Completed:</strong> ${completedSections.length}/${totalSections}
  `;
}

// ===========================
// UTILITIES
// ===========================
function showFeedback(id, type, text) {
  const el = document.getElementById(id);
  if(!el) return;
  el.className = 'feedback-banner show ' + type;
  el.innerHTML = text;
}

function updateCharCount(inputId, countId) {
  const val = document.getElementById(inputId).value;
  const el = document.getElementById(countId);
  if(el) el.textContent = val.length + ' characters';
}

function goBack(fromSection) { showSection(fromSection - 1); }

function showBadge(emoji, title, desc) {
  document.getElementById('badgeEmoji').textContent = emoji;
  document.getElementById('badgeTitle').textContent = title;
  document.getElementById('badgeDesc').textContent = desc;
  document.getElementById('badgePopup').style.display = 'block';
  document.getElementById('overlay').style.display = 'block';
}

function closeBadge() {
  document.getElementById('badgePopup').style.display = 'none';
  document.getElementById('overlay').style.display = 'none';
}

function showPointAnim(text) {
  const el = document.createElement('div');
  el.className = 'point-anim';
  el.textContent = text;
  el.style.left = (Math.random()*60+20) + '%';
  el.style.top = '100px';
  document.body.appendChild(el);
  setTimeout(()=>el.remove(), 1300);
}

function showConfetti() {
  const container = document.getElementById('confetti');
  const colors = ['#52B788','#F4A261','#E76F51','#2D6A4F','#74C69D','#FFD166'];
  for(let i=0;i<50;i++){
    const piece = document.createElement('div');
    piece.className = 'confetti-piece';
    piece.style.left = Math.random()*100+'%';
    piece.style.top = '-10px';
    piece.style.background = colors[Math.floor(Math.random()*colors.length)];
    piece.style.borderRadius = Math.random()>0.5 ? '50%' : '0';
    piece.style.width = (Math.random()*10+5)+'px';
    piece.style.height = (Math.random()*10+5)+'px';
    piece.style.animationDelay = Math.random()*1+'s';
    piece.style.animationDuration = (Math.random()*1.5+1.5)+'s';
    container.appendChild(piece);
    setTimeout(()=>piece.remove(), 3000);
  }
}


function downloadTXT() {
  const name   = studentData.name       || 'Student';
  const cls    = studentData.cls        || '-';
  const no     = studentData.studentNo  || '-';
  const date   = studentData.date       || '-';

  const q3     = (document.getElementById('q3ans')?.value       || '').trim();
  const t2s    = (document.getElementById('t2sender')?.value    || '').trim();
  const t2r    = (document.getElementById('t2receiver')?.value  || '').trim();
  const t2rel  = (document.getElementById('t2relation')?.value  || '').trim();
  const t2sit  = (document.getElementById('t2situation')?.value || '').trim();
  const w1     = (document.getElementById('w1greeting')?.value  || '').trim();
  const w2     = (document.getElementById('w2opening')?.value   || '').trim();
  const w3     = (document.getElementById('w3body')?.value      || '').trim();
  const w4     = (document.getElementById('w4closing')?.value   || '').trim();
  const letter = (document.getElementById('fullLetter')?.value  || '').trim();
  const refl   = (document.getElementById('reflection')?.value  || '').trim();
  const sl1    = document.getElementById('sl1')?.value || '-';
  const sl2    = document.getElementById('sl2')?.value || '-';
  const sl3    = document.getElementById('sl3')?.value || '-';
  const badge  = document.getElementById('finalBadgeName')?.textContent  || '-';
  const emoji  = document.getElementById('finalBadgeEmoji')?.textContent || '';

  const D = '='.repeat(55);
  const d = '-'.repeat(55);

  const lines = [
    D,
    '    LKPD – UNDERSTANDING PERSONAL LETTER',
    '         Grade XI  |  English Language',
    D,
    '',
    'STUDENT INFO',
    d,
    'Name        : ' + name,
    'Class       : ' + cls,
    'Student No  : ' + no,
    'Date        : ' + date,
    'Total Score : ' + totalScore + ' points',
    'Badge       : ' + emoji + ' ' + badge,
    '',
    D,
    'SECTION 1 – WARM UP',
    D,
    'Reflection (last time you wrote a letter):',
    q3 || '(no answer)',
    '',
    D,
    'SECTION 2 – IDENTIFY CONTEXT',
    D,
    'Sender     : ' + (t2s  || '(blank)'),
    'Receiver   : ' + (t2r  || '(blank)'),
    'Relationship: ' + (t2rel || '(blank)'),
    'Purpose    : ' + (t2sit || '(blank)'),
    '',
    D,
    'SECTION 3 – STRUCTURE BUILDER',
    D,
    'Correct order: Date → Greeting → Opening Paragraph',
    '               → Body Paragraph(s) → Closing Statement → Signature',
    '',
    D,
    'SECTION 5 – MICRO WRITING PRACTICE',
    D,
    '1. Greeting line:',
    w1 || '(blank)',
    '',
    '2. Opening paragraph:',
    w2 || '(blank)',
    '',
    '3. Body paragraph:',
    w3 || '(blank)',
    '',
    '4. Closing sentence:',
    w4 || '(blank)',
    '',
    D,
    'SECTION 6 – FULL PERSONAL LETTER',
    'Recipient: ' + (selectedTopic || 'Not chosen'),
    D,
    letter || '(not written)',
    '',
    D,
    'SECTION 7 – SELF-REFLECTION',
    D,
    'I understand personal letter structure : ' + sl1 + '/5',
    'I can write independently              : ' + sl2 + '/5',
    'This lesson was engaging               : ' + sl3 + '/5',
    '',
    'Most valuable learning:',
    refl || '(no answer)',
    '',
    D,
    'END OF LKPD RESULTS',
    'Generated: ' + new Date().toLocaleString(),
    D,
  ];

  const txt  = lines.join('\n');
  const blob = new Blob([txt], { type: 'text/plain;charset=utf-8' });
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  a.href     = url;
  a.download = 'LKPD_' + name.replace(/\s+/g, '_') + '_' + date + '.txt';
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
}

function copyResults() {
  const s = document.getElementById('answerSummary').innerText;
  navigator.clipboard.writeText('LKPD Results\n' + s).then(()=>alert('Summary copied to clipboard!'));
}

// Auto-save to localStorage as backup
function autoSave() {
  const data = {
    score: totalScore,
    student: studentData,
    section: currentSection,
    q3: document.getElementById('q3ans')?.value,
    letter: document.getElementById('fullLetter')?.value,
    topic: selectedTopic
  };
  try { localStorage.setItem('lkpd_autosave', JSON.stringify(data)); } catch(e){}
}
setInterval(autoSave, 10000);
