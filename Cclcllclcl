  <!-- SECTION 5: MICRO WRITING PRACTICE -->
  <div class="section-card" id="sec5">
    <div class="section-header">
      <div class="section-icon">✍️</div>
      <div class="section-meta">
        <div class="slide-sync">📊 Slide Sync: Writing Tips</div>
        <div class="section-num">Section 5 of 8</div>
        <div class="section-title">Micro Writing Practice</div>
      </div>
    </div>

    <p style="font-size:0.9rem;color:var(--text-muted);margin-bottom:20px;">Practice writing each <strong>part</strong> of a personal letter before writing the full version. Focus on tone and clarity!</p>

    <div class="writing-grid">
      <div class="writing-field">
        <label>1. Greeting Line <span class="pts-badge">+5 pts</span></label>
        <input class="q-input" id="w1greeting" placeholder="e.g., Dear Rafi,  /  My dear friend Ayu," oninput="autoCheck('w1greeting','w1fb','greeting')">
